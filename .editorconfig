# EditorConfig — keep formatting consistent across editors and contributors.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,markdown}]
# Markdown is whitespace-sensitive (trailing two spaces = line break).
trim_trailing_whitespace = false

[*.sh]
# Shell scripts: 2-space indents are easier to scan than tabs in heredocs.
indent_size = 2

[Makefile]
indent_style = tab
